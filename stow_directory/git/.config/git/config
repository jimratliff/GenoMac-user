# This is Git's per-user configuration file.
[user]
    name = Default User
    email = default@example.com

[init]
	defaultBranch = main

[core]
	excludesFile = ~/.config/git/git_ignore_global
	editor = bbedit

[pull]
    rebase = true

[rebase]
    autostash = true

[include]
    path = ~/.config/genomac-user/git/gitconfig-personal
