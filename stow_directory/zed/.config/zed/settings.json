// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{

  //Auto-install extensions and themes
  "auto_install_extensions": {
	  "just": true,  // Just language support
      "vscode-dark-high-contrast": true,
      "vscode-icons": true
    },

  // Auto-update set to false because Zed won’t let a normal (non-Homebrew) user update.
  "auto_update": false,

  // UI elements
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 14,

  "tabs": {
  	"file_icons": true,
  },

  "scrollbar": {
    "show": "system"
  },

  // Appearance

  "experimental.theme_overrides": {
    "editor.wrap_guide": "#333",
  },

  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "VSCode Dark High Contrast"
  },

  "icon_theme": {
    "mode": "system",
    "light": "VSCode Icons for Zed (Light Official Icons)",
    "dark": "VSCode Icons for Zed (Dark Official Icons)"
  },

  // Buffer stuff
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 12,
  "buffer_font_features": {
     // Disable ligatures:
     "calt": false
  },

  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 120,
  "show_wrap_guides": true,
  "wrap_guides": [80, 100, 120],
  "hard_tabs": true,

  "show_whitespaces": "all",
  "whitespace_map": {
    "space": "•",
    "tab": "⟶"
  },

  "colorize_brackets": true,
  "show_completion_documentation": false,
  "show_completions_on_input": false,
  "format_on_save": "off",

  // Mulibuffer stuff

    // Double-click on excerpt to open its original file
  "double_click_in_multibuffer": "open",

  // Terminal stuff
  "terminal": {
    "font_size": 12.0,
    "alternate_scroll": "off"
  },

  // Git stuff
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },

  "project_panel": {
    "sort_mode": "mixed"
  },
  "file_finder": {
    "modal_max_width": "medium"
  },
  "message_editor": {
    "auto_replace_emoji_shortcode": false
  },

  "collaboration_panel": { "button": false },

}
